# ── Fillr Server Environment Variables (Local Dev) ─────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

PORT=5000
NODE_ENV=development

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<random-64-char-hex-string>

# Google OAuth 2.0 Client ID (from GCP Console → Credentials)
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# Frontend URL — used in password reset emails
FRONTEND_URL=http://localhost:5500

# Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=YourApp <noreply@yourdomain.com>
